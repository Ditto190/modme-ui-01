{
  "name": "monorepo_modme-root",
  "private": true,
  "packageManager": "yarn@3.3.0",
  "scripts": {
    "contextarch": "node ./scripts/run-contextarch.mjs",
    "contextarch:bootstrap": "node ./scripts/contextarch-bootstrap.mjs",
    "contextarch:verify": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-contextarch.ps1",
    "contextarch:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-contextarch.ps1",
    "agenttrace": ".tools/agenttrace.exe",
    "dev:generative": "yarn --cwd GenerativeUI_monorepo dev",
    "dev:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev",
    "dev:forge:core": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev:core",
    "dev:forge:workshop": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev:workshop",
    "dev:forge:supabase": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run db:start",
    "dev:forge:docs": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev --filter docs",
    "dev:forge:storybook": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev --filter storybook",
    "check:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run check",
    "fix:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run fix",
    "verify:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-forge-ci.ps1",
    "verify:generative": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-generative-ci.ps1",
    "pre-commit:check": "node scripts/pre-commit-checks.mjs",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-git-hooks.ps1",
    "vibe:finish": "powershell -ExecutionPolicy Bypass -File ./scripts/vibe-session-finish.ps1",
    "vibe:finish:dry-run": "powershell -ExecutionPolicy Bypass -File ./scripts/vibe-session-finish.ps1 -DryRun -SkipPull",
    "worktree:ensure": "powershell -ExecutionPolicy Bypass -File ./scripts/ensure-worktree.ps1",
    "worktree:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate-main-to-worktree.ps1",
    "worktree:doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/worktree-doctor.ps1",
    "worktree:doctor:fix": "powershell -ExecutionPolicy Bypass -File ./scripts/worktree-doctor.ps1 -Fix",
    "lspmux:install": "powershell -ExecutionPolicy Bypass -File ./scripts/lspmux/install.ps1",
    "lspmux:start": "powershell -ExecutionPolicy Bypass -File ./scripts/lspmux/start-daemon.ps1",
    "lspmux:start:foreground": "powershell -ExecutionPolicy Bypass -File ./scripts/lspmux/start-daemon.ps1 -Foreground",
    "lspmux:status": "powershell -ExecutionPolicy Bypass -File ./scripts/lspmux/status.ps1",
    "rass:install": "powershell -ExecutionPolicy Bypass -File ./scripts/rassumfrassum/install.ps1",
    "rass:validate": "powershell -ExecutionPolicy Bypass -File ./scripts/rassumfrassum/validate.ps1",
    "worktree:ports": "powershell -ExecutionPolicy Bypass -File ./scripts/load-worktree-ports.ps1",
    "worktree:tmux": "bash ./scripts/agent-workspace-tmux.sh",
    "worktree:tmux:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/agent-workspace-tmux.ps1",
    "agent:mprocs:generate": "node scripts/generate-mprocs-config.mjs",
    "agent:tui": "node scripts/generate-mprocs-config.mjs && npx --yes mprocs",
    "agent:status": "node scripts/agent-status.mjs",
    "agent:status:json": "node scripts/agent-status.mjs --json",
    "agent:audit": "node scripts/agent-audit.mjs",
    "agent:session:start": "powershell -ExecutionPolicy Bypass -File ./scripts/agent-session-start.ps1",
    "agent:session:finish": "powershell -ExecutionPolicy Bypass -File ./scripts/agent-session-finish.ps1",
    "e2e:worktree-smoke": "node e2e/worktree-smoke/run.mjs",
    "supabase:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-supabase-cloud.ps1",
    "supabase:local:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-supabase-local.ps1",
    "supabase:local:env": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-supabase-local-env.ps1",
    "supabase:cloud:env": "powershell -ExecutionPolicy Bypass -File ./scripts/ensure-cloud-supabase-env.ps1",
    "supabase:env:diagnose": "node scripts/diagnose-supabase-env.mjs",
    "intake": "node scripts/run-intake.mjs",
    "intake:dry-run": "node scripts/run-intake.mjs --dry-run",
    "intake:orchestrate": "node scripts/intake-orchestrator.mjs --mode=session",
    "intake:code-index": "node scripts/intake-orchestrator.mjs --mode=code-index",
    "intake:full": "node scripts/intake-orchestrator.mjs --mode=full",
    "intake:scrape": "node scripts/intake-orchestrator.mjs --mode=scrape",
    "scrape:run": "powershell -ExecutionPolicy Bypass -File ./scripts/run-scrape-pipeline.ps1",
    "scrape:classify": "node scripts/scrape-classify.mjs",
    "scrape:promote": "node scripts/scrape-promote.mjs",
    "scrape:harvest": "node scripts/shopping-list-harvest.mjs",
    "scrape:firecrawl": "node scripts/firecrawl-scrape-stage.mjs",
    "scrape:shopping-list": "node scripts/scrape-orchestrator.mjs --manifest=lean-ctx-shopping-list --engine=firecrawl",
    "firecrawl:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/firecrawl/setup-firecrawl.ps1",
    "firecrawl:up": "powershell -ExecutionPolicy Bypass -File ./scripts/firecrawl/up.ps1",
    "firecrawl:down": "powershell -ExecutionPolicy Bypass -File ./scripts/firecrawl/down.ps1",
    "firecrawl:status": "node scripts/firecrawl/status.mjs",
    "inbox:audit": "node scripts/inbox-audit.mjs --lens all",
    "inbox:audit:funnel": "node scripts/inbox-audit.mjs --lens funnel",
    "inbox:fix": "node scripts/inbox-fix.mjs --dry-run",
    "inbox:fix:apply": "node scripts/inbox-fix.mjs --apply",
    "inbox:test": "vitest run scripts/__tests__",
    "inbox:export-contract": "node next-forge/packages/schemas/scripts/export-inbox-contract.mjs",
    "eval:collect": "node scripts/agent-eval-collect.mjs",
    "eval:collect:dry-run": "node scripts/agent-eval-collect.mjs --dry-run",
    "eval:report": "node scripts/agent-eval-report.mjs",
    "eval:report:dry-run": "node scripts/agent-eval-report.mjs --dry-run",
    "telemetry:sync": "node scripts/telemetry/telemetry-cli.mjs sync",
    "telemetry:sync:dry-run": "node scripts/telemetry/telemetry-cli.mjs sync --dry-run",
    "telemetry:collect": "node scripts/telemetry/telemetry-cli.mjs collect",
    "telemetry:report": "node scripts/telemetry/telemetry-cli.mjs report --output reports/observability/latest.html",
    "telemetry:ingest-copilot": "node scripts/telemetry/telemetry-cli.mjs ingest-copilot",
    "telemetry:test:contracts": "cd next-forge/packages/schemas && npx bun test observability.test.ts",
    "telemetry:test": "yarn telemetry:test:contracts && node scripts/telemetry/telemetry-cli.mjs sync --dry-run",
    "telemetry:audit": "node scripts/telemetry-audit.mjs --lens all",
    "telemetry:audit:contracts": "node scripts/telemetry-audit.mjs --lens contracts",
    "collection:validate": "node scripts/validate-collections.mjs",
    "dsp:observability:bootstrap": "node scripts/bootstrap-dsp-observability.mjs",
    "dsp:observability:stats": "python scripts/dsp-cli.py --root . get-stats && python scripts/dsp-cli.py --root . detect-cycles",
    "eval:retrieval": "cd experiments/micro-agents && npm run evaluate:retrieval",
    "beads:init": "powershell -ExecutionPolicy Bypass -File ./scripts/init-beads-starter-issues.ps1",
    "beads:ready": "npx --yes @beads/bd ready",
    "beads:list": "npx --yes @beads/bd list --all",
    "beads:push": "npx --yes @beads/bd dolt push",
    "beads:pull": "npx --yes @beads/bd dolt pull",
    "beads:compact": "npx --yes @beads/bd admin compact --analyze",
    "beads:bfs": "node scripts/beads-bfs-dispatch.mjs",
    "beads:bfs:dry": "node scripts/beads-bfs-dispatch.mjs --dry-run",
    "agent:catalog:seed": "node scripts/lean-ctx-agent-catalog.mjs seed",
    "agent:catalog:validate": "node scripts/lean-ctx-agent-catalog.mjs validate",
    "backlog:health": "node scripts/backlog-health.mjs",
    "test:scripts": "node --test scripts/__tests__/issue-autotag.test.mjs scripts/__tests__/polis-router.test.mjs",
    "lean-ctx:intake": "node scripts/run-lean-ctx-intake.mjs",
    "lean-ctx:index": "node scripts/lean-ctx-universal-intake.mjs",
    "lean-ctx:prove-it": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/lean-ctx-prove-it.ps1",
    "lean-ctx:ensure": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ensure-lean-ctx-config.ps1",
    "lean-ctx:ensure:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/ensure-lean-ctx-config.ps1 -CheckOnly",
    "lean-ctx:trust": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/lean-ctx-trust.ps1",
    "lean-ctx:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -Command \". ./scripts/load-lean-ctx-env.ps1; lean-ctx doctor\"",
    "lean-ctx:schema:sync": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (-not (Test-Path docs/lean-ctx)) { New-Item -ItemType Directory -Force -Path docs/lean-ctx | Out-Null }; lean-ctx config schema | Set-Content -Path docs/lean-ctx/config-schema.json -Encoding utf8\"",
    "agent:catalog:resolve": "node scripts/lean-ctx-agent-catalog.mjs resolve"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "ajv": "^8.17.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "vfile": "^6.0.3",
    "vfile-matter": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "vitest": "^4.0.18"
  }
}
