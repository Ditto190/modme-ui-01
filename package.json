{
  "name": "adk-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:all": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" \"npm run dev:vtcode\" --names ui,agent,vtcode --prefix-colors blue,green,yellow --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:agent": "bash ./scripts/run-agent.sh",
    "dev:ui": "next dev --turbopack",
    "dev:vtcode": "vtcode --mcp-server --port 8080 || echo 'VT Code not installed. Run: npm run vtcode:install'",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:ts && npm run lint:python",
    "lint:ts": "eslint .",
    "lint:python": "ruff check .",
    "lint:fix": "eslint . --fix && ruff check --fix .",
    "format": "prettier --write .  && ruff format .",
    "check": "npm run lint && npm run format",
    "install:all": "./scripts/install-all.sh || scripts\\install-all.bat",
    "install:agent": "./scripts/setup-agent.sh || scripts\\setup-agent.bat",
    "quick-start": "./scripts/quick-start.sh || scripts\\quick-start.bat",
    "postinstall": "npm run install:agent",
    "vtcode:install": "echo 'Please install VT Code manually: cargo install vtcode OR npm install -g vtcode OR brew install vtcode'",
    "validate:toolsets": "node scripts/toolset-management/validate-toolsets.js",
    "validate:naming": "node scripts/toolset-management/validate-naming.js",
    "test:aliases": "node scripts/toolset-management/test-alias-resolution.js",
    "detect:changes": "node scripts/toolset-management/detect-toolset-changes.js",
    "docs:sync": "node scripts/knowledge-management/sync-docs.js --validate-only && node scripts/knowledge-management/sync-docs.js --direction json-to-md",
    "docs:md-to-json": "node scripts/knowledge-management/sync-docs.js --direction md-to-json",
    "docs:json-to-md": "node scripts/knowledge-management/sync-docs.js --direction json-to-md",
    "docs:diagram": "node scripts/knowledge-management/generate-diagram.js",
    "docs:diagram:svg": "node scripts/knowledge-management/generate-diagram.js --format svg",
    "docs:all": "npm run docs:sync && npm run docs:diagram:svg",
    "search:toolset": "bash scripts/knowledge-management/search-toolsets.sh",
    "compress:knowledge": "node scripts/knowledge-management/compress-knowledge.js",
    "search:knowledge": "node scripts/knowledge-management/search-knowledge.js",
    "validate:knowledge-library": "node -e \"const fs=require('fs');const Ajv=require('ajv');const schema=JSON.parse(fs.readFileSync('docs/knowledge-library-schema.json','utf8'));const data=JSON.parse(fs.readFileSync('docs/knowledge-library.json','utf8'));const ajv=new Ajv();const valid=ajv.validate(schema,data);console.log(valid?'✓ Valid':'✗ Invalid:',ajv.errors);process.exit(valid?0:1)\"",
    "inbox:categorize": "node scripts/knowledge-management/categorize-inbox-docs.js",
    "inbox:process": "npm run inbox:categorize && npm run compress:knowledge",
    "hooks:install": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/install-git-hooks.ps1",
    "hooks:test": "node scripts/git-hooks/pre-commit.js",
    "mcp:start": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-local-mcp-servers.ps1",
    "mcp:status": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-mcp-servers.ps1",
    "mcp:start:all": "./scripts/start-all-mcp-servers.sh || pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-all-mcp-servers.ps1",
    "mcp:start:force": "./scripts/start-all-mcp-servers.sh --force || pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-all-mcp-servers.ps1 -Force",
    "mcp:start:wait": "./scripts/start-all-mcp-servers.sh --wait || pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-all-mcp-servers.ps1 -WaitForReady",
    "mcp:start:verbose": "./scripts/start-all-mcp-servers.sh --verbose || pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-all-mcp-servers.ps1 -Verbose",
    "phoenix:setup": "./scripts/setup-phoenix.sh || pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-phoenix.ps1",
    "phoenix:start": "docker-compose -f docker-compose.phoenix.yml up -d",
    "phoenix:stop": "docker-compose -f docker-compose.phoenix.yml down",
    "phoenix:logs": "docker logs phoenix-server -f",
    "phoenix:restart": "npm run phoenix:stop && npm run phoenix:start",
    "phoenix:ui": "echo 'Phoenix UI: http://localhost:6006' && open http://localhost:6006 2>/dev/null || start http://localhost:6006 2>nul || echo 'Open http://localhost:6006 in your browser'",
    "copilot:start": "docker-compose -f docker-compose.phoenix.yml up -d",
    "copilot:stop": "docker-compose -f docker-compose.phoenix.yml down",
    "copilot:logs": "docker-compose -f docker-compose.phoenix.yml logs -f copilot-proxy",
    "copilot:logs:all": "docker-compose -f docker-compose.phoenix.yml logs -f",
    "copilot:restart": "docker-compose -f docker-compose.phoenix.yml restart copilot-proxy",
    "copilot:build": "docker-compose -f docker-compose.phoenix.yml build copilot-proxy",
    "copilot:export": "cd agent && python -m observability.export_copilot_dataset --output-dir ../datasets --format all --days-back 7",
    "copilot:export:finetune": "cd agent && python -m observability.export_copilot_dataset --output-dir ../datasets --format jsonl --finetune-format --days-back 7",
    "copilot:health": "curl http://localhost:8080/health || pwsh -Command \"(Invoke-WebRequest -Uri http://localhost:8080/health).Content\"",
    "copilot:ui": "npm run phoenix:ui",
    "copilot:dev": "npm run copilot:start && npm run copilot:ui",
    "copilot:process-chat": "cd agent && python -m observability.process_chat_json",
    "copilot:parse-chat": "cd agent && python -m observability.copilot_chat_parser",
    "copilot:parse-only": "cd agent && python -m observability.process_chat_json --no-upload --output ../datasets/processed_chat.csv",
    "copilot:validate-schema": "cd agent && python -m observability.copilot_chat_parser --print-schema",
    "copilot:batch-upload": "cd agent && python -m observability.process_chat_json ../datasets/chat.json copilot-demo",
    "observability:start": "npm run copilot:start",
    "observability:stop": "npm run copilot:stop"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.42",
    "@anthropic-ai/sdk": "^0.57.0",
    "@copilotkit/react-core": "1.50.0",
    "@copilotkit/react-ui": "^0.2.0",
    "@copilotkit/runtime": "1.50.0",
    "@supabase/supabase-js": "^2.49.0",
    "next": "^16.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "shiki": "^3.19.0"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "concurrently": "^9.1.2",
    "esbuild": "^0.27.2",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "handlebars": "^4.7.8",
    "markdownlint-rule-github-admonition": "^0.0.1",
    "markdownlint-rule-search-replace": "^1.2.0",
    "marked": "^13.0.3",
    "ofetch": "^1.5.1",
    "markdownlint-cli": "^0.47.0",
    "marked": "^13.0.3",
    "prettier": "^3.7.4",
    "supabase": "^2.70.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "unplugin": "^2.3.11"
  }
}
