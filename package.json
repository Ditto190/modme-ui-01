{
  "name": "monorepo_modme-root",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@latest",
  "scripts": {
    "contextarch": "node ./scripts/run-contextarch.mjs",
    "contextarch:bootstrap": "node ./scripts/contextarch-bootstrap.mjs",
    "contextarch:verify": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-contextarch.ps1",
    "contextarch:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-contextarch.ps1",
    "agenttrace": ".tools/agenttrace.exe",
    "dev:generative": "yarn --cwd GenerativeUI_monorepo dev",
    "dev:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev",
    "dev:forge:core": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev:core",
    "dev:forge:workshop": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev:workshop",
    "dev:forge:supabase": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run db:start",
    "dev:forge:docs": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev --filter docs",
    "dev:forge:storybook": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev --filter storybook",
    "check:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run check",
    "fix:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run fix",
    "verify:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-forge-ci.ps1",
    "pre-commit:check": "node scripts/pre-commit-checks.mjs",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-git-hooks.ps1",
    "vibe:finish": "powershell -ExecutionPolicy Bypass -File ./scripts/vibe-session-finish.ps1",
    "vibe:finish:dry-run": "powershell -ExecutionPolicy Bypass -File ./scripts/vibe-session-finish.ps1 -DryRun -SkipPull",
    "worktree:ensure": "powershell -ExecutionPolicy Bypass -File ./scripts/ensure-worktree.ps1",
    "worktree:migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/migrate-main-to-worktree.ps1",
    "worktree:doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/worktree-doctor.ps1",
    "worktree:doctor:fix": "powershell -ExecutionPolicy Bypass -File ./scripts/worktree-doctor.ps1 -Fix",
    "lspmux:install": "powershell -ExecutionPolicy Bypass -File ./scripts/lspmux/install.ps1",
    "lspmux:start": "powershell -ExecutionPolicy Bypass -File ./scripts/lspmux/start-daemon.ps1",
    "lspmux:status": "powershell -ExecutionPolicy Bypass -File ./scripts/lspmux/status.ps1",
    "worktree:ports": "powershell -ExecutionPolicy Bypass -File ./scripts/load-worktree-ports.ps1",
    "worktree:tmux": "bash ./scripts/agent-workspace-tmux.sh",
    "supabase:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-supabase-cloud.ps1",
    "supabase:local:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-supabase-local.ps1",
    "supabase:local:env": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-supabase-local-env.ps1",
    "intake": "node scripts/run-intake.mjs",
    "intake:dry-run": "node scripts/run-intake.mjs --dry-run",
    "intake:orchestrate": "node scripts/intake-orchestrator.mjs --mode=session",
    "inbox:audit": "node scripts/inbox-audit.mjs --lens all",
    "inbox:audit:funnel": "node scripts/inbox-audit.mjs --lens funnel",
    "inbox:fix": "node scripts/inbox-fix.mjs --dry-run",
    "inbox:fix:apply": "node scripts/inbox-fix.mjs --apply",
    "inbox:test": "vitest run scripts/__tests__",
    "inbox:export-contract": "node next-forge/packages/schemas/scripts/export-inbox-contract.mjs",
    "skills:index": "node scripts/skills-index-generate.mjs",
    "docs:writer:check": "node scripts/documentation-writer-check.mjs",
    "eval:collect": "node scripts/agent-eval-collect.mjs",
    "eval:collect:dry-run": "node scripts/agent-eval-collect.mjs --dry-run",
    "agent-eval:collect": "node scripts/agent-eval-collect.mjs",
    "agent-eval:collect:dry-run": "node scripts/agent-eval-collect.mjs --dry-run",
    "eval:report": "node scripts/agent-eval-report.mjs",
    "eval:report:dry-run": "node scripts/agent-eval-report.mjs --dry-run",
    "agent-eval:report": "node scripts/agent-eval-report.mjs",
    "session:docs": "node scripts/session-to-docs.mjs --dry-run",
    "session:docs:apply": "node scripts/session-to-docs.mjs --apply",
    "hooks:session:bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File ./.cursor/hooks/session-bootstrap.ps1",
    "hooks:session:capture": "powershell -NoProfile -ExecutionPolicy Bypass -File ./.cursor/hooks/session-capture.ps1",
    "lean-ctx:sync-config": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/lean-ctx/sync-config.ps1",
    "gitkraken:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/gitkraken/setup-cursor.ps1",
    "beads:init": "powershell -ExecutionPolicy Bypass -File ./scripts/init-beads-starter-issues.ps1",
    "beads:ready": "npx --yes @beads/bd ready",
    "beads:list": "npx --yes @beads/bd list --all",
    "beads:push": "npx --yes @beads/bd dolt push",
    "beads:pull": "npx --yes @beads/bd dolt pull",
    "beads:compact": "npx --yes @beads/bd admin compact --analyze"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "prisma": "^7.8.0",
    "vitest": "^4.0.18"
  }
}