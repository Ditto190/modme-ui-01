{
  "name": "monorepo_modme-root",
  "private": true,
  "packageManager": "yarn@3.3.0",
  "scripts": {
    "contextarch": "node ./scripts/run-contextarch.mjs",
    "contextarch:bootstrap": "node ./scripts/contextarch-bootstrap.mjs",
    "contextarch:verify": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-contextarch.ps1",
    "contextarch:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-contextarch.ps1",
    "agenttrace": ".tools/agenttrace.exe",
    "dev:generative": "yarn --cwd GenerativeUI_monorepo dev",
    "dev:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev",
    "dev:forge:core": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev:core",
    "dev:forge:workshop": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev:workshop",
    "dev:forge:supabase": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run db:start",
    "dev:forge:docs": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev --filter docs",
    "dev:forge:storybook": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run dev --filter storybook",
    "check:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run check",
    "fix:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/run-forge-bun.ps1 run fix",
    "verify:forge": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-forge-ci.ps1",
    "verify:generative": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-generative-ci.ps1",
    "beads:init": "powershell -ExecutionPolicy Bypass -File ./scripts/init-beads-starter-issues.ps1",
    "pre-commit:check": "node scripts/pre-commit-checks.mjs",
    "hooks:install": "powershell -ExecutionPolicy Bypass -File ./scripts/install-git-hooks.ps1"
  }
}