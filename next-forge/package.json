{
  "name": "next-forge",
  "version": "6.0.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel/next-forge.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "bin": {
    "next-forge": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "node scripts/with-forge-dev.mjs bunx turbo dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "turbo test",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-deps": "bunx npm-check-updates --deep -u && bun install",
    "bump-ui": "bunx shadcn@latest add --all --overwrite -c packages/design-system",
    "db:start": "cd packages/database && bunx supabase start --workdir ../.. --dns-resolver https",
    "db:stop": "cd packages/database && bunx supabase stop --workdir ../..",
    "db:status": "cd packages/database && bunx supabase status --workdir ../..",
    "db:link": "cd packages/database && bunx supabase link --workdir ../.. --dns-resolver https --project-ref aevemmmmouxqlfyxthzf --yes",
    "db:remote:push": "cd packages/database && bunx supabase db push --workdir ../.. --dns-resolver https --yes",
    "db:local:push": "cd packages/database && bunx supabase db push --local --workdir ../.. --yes",
    "db:local:setup": "powershell -ExecutionPolicy Bypass -File ../scripts/setup-supabase-local.ps1",
    "intake": "node ../scripts/run-intake.mjs",
    "intake:dry-run": "node ../scripts/run-intake.mjs --dry-run",
    "migrate": "cd packages/database && bunx prisma format && bunx prisma generate && bunx prisma migrate dev",
    "migrate:deploy": "cd packages/database && bunx prisma generate && bunx prisma migrate deploy",
    "db:push": "cd packages/database && bunx prisma format && bunx prisma generate && bunx prisma db push",
    "dev:core": "node scripts/with-forge-dev.mjs bunx turbo dev --filter=app --filter=web --filter=api",
    "dev:workshop": "node scripts/with-forge-dev.mjs bunx turbo dev --filter=docs --filter=storybook",
    "clean": "git clean -xdf node_modules",
    "release": "npm publish"
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.6",
    "@biomejs/biome": "2.4.6",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.8.14",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "commander": "^14.0.3",
    "nypm": "^0.6.5"
  },
  "overrides": {
    "parse5": "^7.2.1"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}