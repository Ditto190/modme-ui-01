# ModMe local URLs
NEXT_PUBLIC_APP_URL=http://localhost:3100
NEXT_PUBLIC_WEB_URL=http://localhost:3101
NEXT_PUBLIC_API_URL=http://localhost:3102
NEXT_PUBLIC_DOCS_URL=http://localhost:3104

# Auth.js (local credentials)
AUTH_SECRET=modme-local-dev-secret-change-in-production
AUTH_DEV_EMAIL=dev@modme.local
AUTH_DEV_PASSWORD=devpassword

# Database (Supabase local — same as packages/database/.env)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
