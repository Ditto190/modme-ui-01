// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// Stub model — kept for reference
model Page {
  id   Int    @id @default(autoincrement())
  name String
}

// ─── Inbox Pipeline Models ────────────────────────────────────────────────────
// Managed by: scripts/inbox-ingest.mjs + MDA Pipeline
// See: GenerativeUI_monorepo/docs/inbox/README.md

model InboxEntry {
  id              String           @id @default(uuid())
  contentHash     String           @unique @map("content_hash")
  sourceFile      String           @map("source_file")
  sourceFormat    String           @map("source_format")
  rawContent      String?          @map("raw_content")
  extractedText   String?          @map("extracted_text")
  title           String?
  summary         String?
  agentName       String?          @map("agent_name")
  agentRole       String?          @map("agent_role")
  sessionId       String?          @map("session_id")
  branchName      String?          @map("branch_name")
  prNumber        Int?             @map("pr_number")
  tags            String[]
  severity        String           @default("medium")
  entryType       String?          @map("entry_type")
  status          String           @default("indexed")
  sourceKind      String?          @map("source_kind")
  codePatternIds  String[]         @default([]) @map("code_pattern_ids")
  storageUrl      String?          @map("storage_url")
  categoryId      String?          @map("category_id")
  category        Category?        @relation(fields: [categoryId], references: [id])
  relations       EntryRelation[]  @relation("from_entry")
  relatedBy       EntryRelation[]  @relation("to_entry")
  outputArtefacts OutputArtefact[]
  scrapePages     ScrapePage[]
  codePatternRefs CodePatternRef[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  archivedAt      DateTime?        @map("archived_at")
  archiveLocation String?          @map("archive_location")

  @@map("inbox_entries")
}

model EntryRelation {
  id           String     @id @default(uuid())
  fromEntryId  String     @map("from_entry_id")
  toEntryId    String     @map("to_entry_id")
  relationType String     @map("relation_type")
  confidence   Float      @default(1.0)
  fromEntry    InboxEntry @relation("from_entry", fields: [fromEntryId], references: [id])
  toEntry      InboxEntry @relation("to_entry", fields: [toEntryId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([fromEntryId, toEntryId, relationType])
  @@map("entry_relations")
}

model Category {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  description String?
  parentId    String?      @map("parent_id")
  parent      Category?    @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]   @relation("CategoryTree")
  entries     InboxEntry[]
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("categories")
}

model OutputSchema {
  id            String           @id @default(uuid())
  schemaType    String           @map("schema_type")
  name          String
  slug          String           @unique
  version       String           @default("1.0.0")
  schema        Json
  sourceEntryId String?          @map("source_entry_id")
  artefacts     OutputArtefact[]
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@map("output_schemas")
}

model OutputArtefact {
  id            String        @id @default(uuid())
  artefactType  String        @map("artefact_type")
  title         String
  content       String
  filePath      String?       @map("file_path")
  status        String        @default("draft")
  sourceEntryId String?       @map("source_entry_id")
  schemaId      String?       @map("schema_id")
  sourceEntry   InboxEntry?   @relation(fields: [sourceEntryId], references: [id])
  schema        OutputSchema? @relation(fields: [schemaId], references: [id])
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("output_artefacts")
}

model CodePatternRef {
  id           String     @id @default(uuid())
  inboxEntryId String     @map("inbox_entry_id")
  greptimeId   String     @map("greptime_id")
  path         String?
  astKind      String?    @map("ast_kind")
  contentHash  String?    @map("content_hash")
  inboxEntry   InboxEntry @relation(fields: [inboxEntryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([inboxEntryId, greptimeId])
  @@index([inboxEntryId])
  @@index([greptimeId])
  @@map("code_pattern_refs")
}

// ─── Scrape Staging Models ────────────────────────────────────────────────────
// Crawl → classify → promote into inbox_entries (Scrapy + Ollama pipeline)

model ScrapeManifest {
  id        String      @id @default(uuid())
  slug      String      @unique
  seeds     Json
  rules     Json
  schedule  String?
  jobs      ScrapeJob[]
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("scrape_manifests")
}

model ScrapeJob {
  id          String         @id @default(uuid())
  manifestId  String         @map("manifest_id")
  status      String         @default("pending")
  startedAt   DateTime?      @map("started_at")
  completedAt DateTime?      @map("completed_at")
  error       String?
  manifest    ScrapeManifest @relation(fields: [manifestId], references: [id], onDelete: Cascade)
  pages       ScrapePage[]
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([manifestId, startedAt(sort: Desc)])
  @@map("scrape_jobs")
}

model ScrapePage {
  id             String                @id @default(uuid())
  jobId          String                @map("job_id")
  url            String
  contentHash    String                @unique @map("content_hash")
  html           String?
  text           String?
  status         String                @default("raw")
  inboxEntryId   String?               @map("inbox_entry_id")
  job            ScrapeJob             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inboxEntry     InboxEntry?           @relation(fields: [inboxEntryId], references: [id], onDelete: SetNull)
  classification ScrapeClassification?
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  @@index([jobId, status])
  @@map("scrape_pages")
}

model ScrapeClassification {
  id         String     @id @default(uuid())
  pageId     String     @unique @map("page_id")
  entryType  String     @map("entry_type")
  severity   String     @default("medium")
  agentRole  String?    @map("agent_role")
  title      String
  summary    String
  tags       String[]
  features   Json       @default("{}")
  promotedAt DateTime?  @map("promoted_at")
  page       ScrapePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now()) @map("created_at")

  @@map("scrape_classifications")
}

// ─── Observability & Telemetry Models ─────────────────────────────────────────

model TelemetryCategory {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  events      TelemetryEvent[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("telemetry_categories")
}

model Tenant {
  id                  String               @id @default(uuid())
  slug                String               @unique
  name                String
  metadata            Json                 @default("{}")
  telemetryEvents     TelemetryEvent[]
  evalSessions        EvalSession[]
  evalSignals         EvalSignal[]
  evalEvents          EvalEvent[]
  evalContractResults EvalContractResult[]
  pipelineRuns        PipelineRun[]
  traceRefs           TraceRef[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@map("tenants")
}

model TelemetryEvent {
  id         String             @id @default(uuid())
  tenantId   String             @map("tenant_id")
  sessionId  String?            @map("session_id")
  message    String
  source     String
  level      String             @default("info")
  metadata   Json               @default("{}")
  categoryId String?            @map("category_id")
  category   TelemetryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  traceRefs  TraceRef[]
  createdAt  DateTime           @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([sessionId])
  @@index([level, createdAt(sort: Desc)])
  @@map("telemetry_events")
}

model PipelineRun {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  pipeline          String    @default("telemetry")
  mode              String    @default("collect")
  triggerSource     String    @default("manual") @map("trigger_source")
  status            String    @default("running")
  startedAt         DateTime  @default(now()) @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  sourcePath        String?   @map("source_path")
  stats             Json      @default("{}")
  errorMessage      String?   @map("error_message")
  metadata          Json      @default("{}")
  sessionsParsed    Int       @default(0) @map("sessions_parsed")
  toolCallsUpserted Int       @default(0) @map("tool_calls_upserted")
  metricsWritten    Int       @default(0) @map("metrics_written")
  errors            Int       @default(0)
  durationMs        BigInt?   @map("duration_ms")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([pipeline, status, startedAt(sort: Desc)])
  @@map("pipeline_runs")
}

model TraceRef {
  id               String         @id @default(uuid())
  telemetryEventId String         @map("telemetry_event_id")
  greptimeSpanId   String         @map("greptime_span_id")
  tenantId         String         @map("tenant_id")
  traceId          String?        @map("trace_id")
  sessionId        String?        @map("session_id")
  spanName         String?        @map("span_name")
  attributes       Json           @default("{}")
  telemetryEvent   TelemetryEvent @relation(fields: [telemetryEventId], references: [id], onDelete: Cascade)
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@unique([telemetryEventId, greptimeSpanId])
  @@index([telemetryEventId])
  @@index([greptimeSpanId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("trace_refs")
}

// Managed by: 006_eval_pipeline.sql + agent-eval scripts
// See: docs/evaluation/ARCHITECTURE.md

model EvalTheme {
  id           String       @id
  label        String
  description  String?
  taxonomyCode String?      @map("taxonomy_code")
  aliases      Json         @default("[]")
  signals      EvalSignal[]
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("eval_themes")
}

model EvalSession {
  id                String       @id @default(uuid())
  tenantId          String       @map("tenant_id")
  externalSessionId String       @unique @map("external_session_id")
  agent             String?
  worktreePath      String?      @map("worktree_path")
  branch            String?
  startedAt         DateTime?    @map("started_at")
  endedAt           DateTime?    @map("ended_at")
  metadata          Json         @default("{}")
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  signals           EvalSignal[]
  createdAt         DateTime     @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([startedAt(sort: Desc)])
  @@map("eval_sessions")
}

model EvalSignal {
  id           String       @id @default(uuid())
  tenantId     String       @map("tenant_id")
  sessionId    String?      @map("session_id")
  themeId      String?      @map("theme_id")
  source       String
  title        String
  description  String?
  impact       String       @default("medium")
  evidence     Json         @default("{}")
  taxonomyCode String?      @map("taxonomy_code")
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session      EvalSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  theme        EvalTheme?   @relation(fields: [themeId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([themeId])
  @@index([impact])
  @@map("eval_signals")
}

model EvalEvent {
  id              String               @id @default(uuid())
  tenantId        String               @map("tenant_id")
  pipeline        String               @default("agent-eval")
  mode            String               @default("collect")
  triggerSource   String               @default("manual") @map("trigger_source")
  status          String               @default("running")
  startedAt       DateTime             @default(now()) @map("started_at")
  finishedAt      DateTime?            @map("finished_at")
  stats           Json                 @default("{}")
  errorMessage    String?              @map("error_message")
  metadata        Json                 @default("{}")
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contractResults EvalContractResult[]
  createdAt       DateTime             @default(now()) @map("created_at")

  @@index([tenantId, startedAt(sort: Desc)])
  @@map("eval_events")
}

model EvalContractResult {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  evalEventId  String?    @map("eval_event_id")
  contractName String     @map("contract_name")
  ruleId       String     @map("rule_id")
  passed       Boolean
  severity     String
  evidence     Json       @default("{}")
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  evalEvent    EvalEvent? @relation(fields: [evalEventId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([evalEventId])
  @@map("eval_contract_results")
}
