{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/block-models-by-repo-origin.sh",
        "matcher": "UserPromptSubmit",
        "timeout": 5,
        "failClosed": true
      },
      {
        "command": ".cursor/hooks/sensitive-prompt-guard.sh",
        "matcher": "UserPromptSubmit",
        "timeout": 5,
        "failClosed": true
      },
      {
        "command": ".cursor/hooks/audit-log.sh",
        "matcher": "UserPromptSubmit",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/audit-log.sh",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterShellExecution": [
      {
        "command": ".cursor/hooks/audit-log.sh",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/audit-log.sh",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/update-skills-on-stop.mjs",
        "timeout": 10,
        "loop_limit": 1,
        "failClosed": false
      },
      {
        "command": "bun run ${CURSOR_PLUGIN_ROOT}/hooks/continual-learning-stop.ts"
      },
      {
        "command": ".cursor/hooks/stop-hook.sh",
        "loop_limit": null
      }
    ],
    "afterAgentResponse": [
      {
        "command": ".cursor/hooks/capture-response.sh"
      }
    ]
  }
}