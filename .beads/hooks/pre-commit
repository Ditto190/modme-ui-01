#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v1.0.5 ---
# This section is managed by beads. Do not remove these markers.
run_bd() {
  if command -v bd >/dev/null 2>&1 && bd version >/dev/null 2>&1; then
    bd "$@"
  elif command -v npx >/dev/null 2>&1; then
    npx --yes @beads/bd "$@"
  else
    return 127
  fi
}
if command -v bd >/dev/null 2>&1 || command -v npx >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  run_bd hooks run pre-commit "$@"
  _bd_exit=$?
  if [ $_bd_exit -eq 3 ] || [ $_bd_exit -eq 1 ]; then
    echo >&2 "beads: pre-commit hook skipped (exit $_bd_exit)"
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.0.5 ---

# ModMe repo checks (mirrors .githooks/pre-commit)
set -e
branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  echo "pre-commit: direct commits to $branch are not allowed. Use a feature worktree/branch."
  exit 1
fi
node scripts/pre-commit-checks.mjs
