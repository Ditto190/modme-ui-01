#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v1.0.5 ---
run_bd() {
  if command -v bd >/dev/null 2>&1 && bd version >/dev/null 2>&1; then
    bd "$@"
  elif command -v npx >/dev/null 2>&1; then
    npx --yes @beads/bd "$@"
  else
    return 127
  fi
}
if command -v bd >/dev/null 2>&1 || command -v npx >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  run_bd hooks run prepare-commit-msg "$@"
  _bd_exit=$?
  if [ $_bd_exit -eq 3 ] || [ $_bd_exit -eq 1 ]; then
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.0.5 ---

# ModMe conventional commit warn-only
commit_msg_file="$1"
msg=$(head -n 1 "$commit_msg_file")
if ! echo "$msg" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'; then
  echo "commit-msg: warning — message does not match conventional commits:"
  echo "  $msg"
  echo "  expected: type(scope): description"
fi
exit 0
