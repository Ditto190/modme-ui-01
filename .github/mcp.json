{
  "mcpServers": {
    "GitLab": {
      "type": "http",
      "url": "https://gitlab.com/api/v4/mcp"
    },
    "github-agentic-workflows": {
      "args": [
        "aw",
        "mcp-server"
      ],
      "command": "gh"
    },
    "mantine": {
      "args": [
        "-y",
        "@mantine/mcp-server"
      ],
      "command": "npx"
    }
  }
}