{
  "logLevel": "info",
  "skipLoggingEnvVar": "SKIP_LOGGING",
  "logsDir": "logs\\copilot",
  "trackedFiles": [
    "GenerativeUI_monorepo\\UniversalWorkbench\\.flow\\README.md",
    "GenerativeUI_monorepo\\UniversalWorkbench\\.flow\\behavior-management.md",
    "GenerativeUI_monorepo\\UniversalWorkbench\\docs\\FEATURE-TAXONOMY.md"
  ],
  "powershellWrapper": "session-logger.ps1",
  "events": [
    "sessionStart",
    "sessionEnd",
    "prompt",
    "toolCall",
    "userCorrection",
    "hookFire",
    "handoff"
  ],
  "emitFields": [
    "agent",
    "agent_platform",
    "worktree",
    "branch",
    "parent_session_id"
  ],
  "handoff": {
    "propagateFields": ["parent_session_id", "trace_id", "agent_platform"]
  }
}
