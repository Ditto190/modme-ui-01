{
  "elements": [
    {
      "id": "StatCard",
      "title": "Stat Card",
      "enabled": true,
      "category": "kpi",
      "requiredProps": ["title", "value"],
      "promptHint": "Use for headline KPI metrics such as active projects, at-risk count, and blockers.",
      "defaultSize": { "cols": 1, "rows": 1 }
    },
    {
      "id": "DataTable",
      "title": "Data Table",
      "enabled": true,
      "category": "operations",
      "requiredProps": ["columns", "data"],
      "promptHint": "Use for tabular operational data like blocked tasks, milestones, or owner assignments.",
      "defaultSize": { "cols": 3, "rows": 2 }
    },
    {
      "id": "ChartCard",
      "title": "Chart Card",
      "enabled": true,
      "category": "analytics",
      "requiredProps": ["title", "chartType", "data"],
      "promptHint": "Use for trend visualizations such as burndown, throughput, and utilization over time.",
      "defaultSize": { "cols": 2, "rows": 2 },
      "refreshIntervalMs": 30000
    }
  ],
  "presets": [
    {
      "id": "project_management_starter",
      "label": "Project Management Starter",
      "category": "project-management",
      "description": "Starter canvas with portfolio KPIs, blocker feed, and delivery trend.",
