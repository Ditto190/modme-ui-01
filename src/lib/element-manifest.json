          "type": "DataTable",
          "props": {
            "columns": ["Project", "Issue", "Owner", "Age"],
            "data": [
              { "Project": "Apollo", "Issue": "API migration", "Owner": "Sam", "Age": "3d" },
              { "Project": "Nova", "Issue": "QA backlog", "Owner": "Priya", "Age": "2d" }
