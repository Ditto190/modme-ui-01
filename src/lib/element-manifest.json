  "variants": [
    {
      "id": "default",
      "label": "Default Workspace",
      "panels": ["StatCard", "DataTable", "ChartCard"],
      "recommendedPreset": "project_management_starter"
    },
    {
      "id": "project_management",
      "label": "Project Management Workspace",
      "panels": ["StatCard", "DataTable", "ChartCard"],
