# Copy to .env and fill in. Never commit .env.

AUTH_MODE=static

# local = dev on laptop (no AWS). s3 = production / CI-backed cache.
STORAGE_PROVIDER=local
STORAGE_PATH=/mnt/cache
STORAGE_PATH_USE_TMP_FOLDER=false

# --- S3 only (set STORAGE_PROVIDER=s3) ---
# STORAGE_PROVIDER=s3
# STORAGE_PATH=modme-turbo-cache
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1

TURBO_TOKEN=
TURBO_REMOTE_CACHE_SIGNATURE_KEY=

PORT=8080
