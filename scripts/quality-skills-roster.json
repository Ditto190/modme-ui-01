    {
      "id": "turborepo",
      "role": "next-forge task graph, boundaries, cache",
      "install": "npx skills add vercel/turborepo@turborepo --agent cursor -y"
    },
    {
      "id": "vitest-testing",
      "role": "Root + package test patterns",
      "install": "npx skills add oakoss/agent-skills@vitest-testing --agent cursor -y"
    },
    {
      "id": "test-automator",
      "role": "Test scaffolding automation",
      "install": "npx skills add sickn33/antigravity-awesome-skills@test-automator --agent cursor -y"
    },
    {
      "id": "testing-cicd-init",
      "role": "CI bootstrap patterns",
      "install": "npx skills add shipshitdev/library@testing-cicd-init --agent cursor -y"
    },
    {
      "id": "github-pr-query",
      "role": "PR/check introspection for gh-aw",
      "install": "npx skills add github/gh-aw@github-pr-query --agent cursor -y"
    },
    {
      "id": "github-automation",
      "role": "Label/comment automation",
      "install": "npx skills add ruvnet/ruflo@github-automation --agent cursor -y"
    },
    {
      "id": "review-pull-request",
