# Copy to .env at repo root and set values locally. Never commit .env.
# Add variable names your apps read (see docs/agent-tech-guide.md and package READMEs).

# Example placeholders (replace or remove unused):
# NODE_ENV=development
# DATABASE_URL=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# --- lean-ctx (ModMe multi-agent; project overrides global) ---
# Dot-source: . .\scripts\load-lean-ctx-env.ps1
# LEAN_CTX_DATA_DIR=data/lean-ctx
# LEAN_CTX_STATE_DIR=logs/lean-ctx
# LEAN_CTX_CACHE_DIR=data/lean-ctx/cache
# LEAN_CTX_PROFILE=orchestration
# LEAN_CTX_EVAL_MODEL=gpt-4o-mini
# LEAN_CTX_EVAL_MODEL_URL=
# LEAN_CTX_EVAL_MODEL_KEY=

