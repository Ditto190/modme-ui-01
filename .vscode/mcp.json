      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "gitkraken": {
      "command": "C:\\Users\\dylan\\AppData\\Local\\Microsoft\\WinGet\\Packages\\GitKraken.cli_Microsoft.Winget.Source_8wekyb3d8bbwe\\gk.exe",
      "args": [
        "mcp",
