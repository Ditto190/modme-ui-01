{
  "terminal.integrated.profiles.windows": {
    "Worktree PowerShell": {
      "source": "PowerShell",
      "args": [
        "-NoExit",
        "-Command",
        "if (Test-Path .worktree-ports.env) { Get-Content .worktree-ports.env | Foreach-Object { if ($_ -match '^([^=]+)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } } }"
      ]
    }
  },
  "terminal.integrated.defaultProfile.windows": "Worktree PowerShell",
  "files.exclude": {
    "**/.git": true
  }
}