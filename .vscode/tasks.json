{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vibe-web-app: dev",
      "type": "shell",
      "command": "yarn dev",
      "options": {
        "cwd": "${workspaceFolder}/GenerativeUI_monorepo/apps/vibe-web-app"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:\\s+http://localhost:3000|ready in \\d+)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "agent-generator: build",
      "type": "shell",
      "command": "yarn build",
      "options": {
        "cwd": "${workspaceFolder}/GenerativeUI_monorepo/apps/agent-generator"
      },
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "agenttrace: overview",
      "type": "shell",
      "command": "yarn agenttrace --overview",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "forge-docs: dev",
      "type": "shell",
      "command": "bun run dev",
      "options": {
        "cwd": "${workspaceFolder}/next-forge/apps/docs"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "mintlify",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(ready|Local:\\s+http://localhost:3104)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "forge-storybook: dev",
      "type": "shell",
      "command": "bun run dev",
      "options": {
        "cwd": "${workspaceFolder}/next-forge/apps/storybook"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "storybook",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(Local:\\s+http://localhost:6106|ready in \\d+)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
