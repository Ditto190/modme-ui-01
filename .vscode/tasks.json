{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Worktree Init & Dev",
      "type": "shell",
      "command": "yarn install && yarn worktree:doctor:fix && yarn dev:forge",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting.*$",
          "endsPattern": "^.*Ready on.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
