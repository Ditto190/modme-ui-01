{
  "name": "micro-agents",
  "version": "1.0.0",
  "description": "Minimal agent runners with embeddings, evaluation, and tracing",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "base": "npm run build && node dist/base/agent.js",
    "embedded": "npm run build && node dist/base/embedding-agent.js",
    "traced": "npm run build && node dist/base/traced-agent.js",
    "helper:review": "npm run build && node dist/helpers/code-review-helper.js",
    "helper:refactor": "npm run build && node dist/helpers/refactor-helper.js",
    "helper:tests": "npm run build && node dist/helpers/test-generator-helper.js",
    "helper:scrape-classify": "npm run build && node -e \"import('./dist/helpers/scrape-classifier-helper.js').then(m=>m.classifyScrapePage({url:'https://example.com',text:'Sample docs page about React hooks and state management.'}).then(console.log))\"",
    "code:index": "npm run build && node dist/workers/ast-indexer.js",
    "evaluate": "npm run build && node dist/evaluation/runner.js",
    "evaluate:retrieval": "npm run build && node dist/evaluation/runner.js --retrieval-only"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/instrumentation": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@xenova/transformers": "^2.17.2",
    "pg": "^8.13.1",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.0"
  }
}
