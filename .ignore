# Un-ignore all non-bloat files in .vendor except those that are typical bloat (e.g., node_modules)
!.vendor/
.vendor/*
# Allow everything inside .vendor except node_modules or other bloat folders
!.vendor/**/
!.vendor/**/*
.vendor/**/node_modules/
.vendor/**/node_modules/**

# Ignore local skills directories to prevent search/indexing bloat
.agents/skills/
.agents/temp_skills/
.cursor/skills/
.vendor/**/skills/
